# Copy to .env in this directory or export before `npm start` (see parent docs)

# Required: shared secret with eve-core (HMAC)
TRIGGER_HMAC_SECRET=

# Required: deployer Solana keypair (JSON [1,2,...] or base58 secret)
DEPLOYER_KEYPAIR=

# RPC (use private / paid endpoint in production)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Loopback bind
DEPLOY_AGENT_HOST=127.0.0.1
DEPLOY_AGENT_PORT=4077

# If TRIGGER omits imageUrl, set a public https default image
DEFAULT_TOKEN_IMAGE_URL=

# Idempotency store (JSON file)
IDEMPOTENCY_STORE_PATH=

# Optional: Jito Block Engine base URL, e.g. https://mainnet.block-engine.jito.wtf
JITO_BLOCK_ENGINE_URL=

# Optional priority fee
COMPUTE_UNIT_PRICE_MICRO_LAMPORTS=
COMPUTE_UNIT_LIMIT=

# 1 = sendRawTransaction skipPreflight
SKIP_PREFLIGHT=0

# Dry run: simulate only (set DRY_RUN_SKIP_IPFS=1 to avoid IPFS upload)
DRY_RUN=0
DRY_RUN_SKIP_IPFS=0

# Default skip vanity mint (fast) unless TRIGGER sets skipVanityMint: false
VANITY_DEFAULT_SKIP=1
VANITY_SUFFIX=

# Optional: POST result to eve-core when deploy finishes
DEPLOY_CALLBACK_URL=
DEPLOY_CALLBACK_HMAC_SECRET=
